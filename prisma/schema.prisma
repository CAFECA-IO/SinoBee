generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  identityAddress  String?  @map("identity_address") // Info: (20260112 - Tzuhan) RWA Identity Contract (ONCHAINID)
  address          String   @unique //  Info: (20260112 - Tzuhan) 用戶的錢包 (address) 是這個 RWA Identity Contract 合約的 Owner
  pubKeyX          String?  @map("pub_key_x")
  pubKeyY          String?  @map("pub_key_y")
  credentialId     String?  @unique @map("credential_id")
  currentChallenge String?  @map("current_challenge")
  name             String?
  imageUrl         String?  @map("image_url")
  kycData          String?  @map("kyc_data") // Changed from Json to String for SQLite compatibility
  role             String   @default("USER") // Changed from enum to String for SQLite compatibility
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user")
  @@index([address])
}
